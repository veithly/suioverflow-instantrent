# ============ SuiOverflow / InstantRent ============

# --- Sui Testnet ---
SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# Server-only demo signer (env-baked private key, never exposed to the client).
# Use a fresh dedicated key for the demo; do NOT reuse a personal wallet.
SUI_DEMO_PRIVATE_KEY=

# --- Deployed Move package (filled after publish) ---
NEXT_PUBLIC_INSTANTRENT_PACKAGE_ID=
NEXT_PUBLIC_INSTANTRENT_REGISTRY_ID=

# --- StepFun (primary LLM + TTS, shared SuiOverflow workspace key) ---
STEPFUN_API_BASE=https://api.stepfun.com/v1
STEPFUN_API_KEY=
STEPFUN_LLM_MODEL=step-3.6
STEPFUN_TTS_MODEL=stepaudio-2.5-tts

# --- OpenAI (fallback only) ---
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3120
